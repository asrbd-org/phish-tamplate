# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
# Visit https://core.telegram.org/bots/tutorial to create a bot
NEXT_PUBLIC_TELEGRAM_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefg

# Your Telegram Chat ID
# Send a message to your bot and visit:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
# Look for "id" field in the chat object
NEXT_PUBLIC_TELEGRAM_CHAT_ID=1234567890

# Application Configuration (Optional)
# The API URL for the application (usually auto-detected)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Application Name
NEXT_PUBLIC_APP_NAME=Phish Template

# Example of a non-public environment variable (backend only)
# This will NOT be exposed to the browser
# INTERNAL_API_SECRET=your_secret_key_here

